{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codos",
  "version": "1.3.1",
  "identifier": "com.codos.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix ../frontend run dev -- --host 127.0.0.1 --port 5174",
    "beforeBuildCommand": "npm --prefix ../frontend run build",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codos",
        "width": 1400,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "resources": [
      "resources/python/**/*",
      "resources/bun/**/*",
      "resources/services/**/*",
      "resources/ingestion/**/*",
      "resources/skills/**/*",
      "resources/bundle-manifest.json",
      "resources/env.sh"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "signingIdentity": "-",
      "entitlements": "Entitlements.plist",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      },
      "infoPlist": "Info.plist"
    }
  }
}
